<!DOCTYPE html>
<html>
<head>
    <title>Image Gallery</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<h1>Responsive Image Gallery</h1>

<div class="gallery">
    <img src="https://picsum.photos/id/1015/600/400" onclick="openLightbox(this.src)">
    <img src="https://picsum.photos/id/1016/600/400" onclick="openLightbox(this.src)">
    <img src="https://picsum.photos/id/1018/600/400" onclick="openLightbox(this.src)">
    <img src="https://picsum.photos/id/1025/600/400" onclick="openLightbox(this.src)">
    <img src="https://picsum.photos/id/1035/600/400" onclick="openLightbox(this.src)">
    <img src="https://picsum.photos/id/1040/600/400" onclick="openLightbox(this.src)">
</div>

<div id="lightbox">
    <span class="close" onclick="closeLightbox()">&times;</span>
    <button class="prev" onclick="changeImage(-1)">❮</button>
    <img id="lightbox-img">
    <button class="next" onclick="changeImage(1)">❯</button>
</div>

<script src="script.js"></script>
</body>
</html>
